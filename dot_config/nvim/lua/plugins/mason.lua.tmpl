# ~/.local/share/chezmoi/dot_config/nvim/lua/plugins/mason.lua.tmpl
return {
    -- Mason: Package manager for LSP servers, formatters, linters, etc.
    {
        "williamboman/mason.nvim",
        config = function()
            require("mason").setup({
                ui = {
                    icons = {
                        package_installed = "✓",
                        package_pending = "➜",
                        package_uninstalled = "✗"
                    }
                }
            })
        end
    },
    -- Mason-LSPConfig: Bridge between mason and lspconfig
    {
        "williamboman/mason-lspconfig.nvim",
        dependencies = {
            "williamboman/mason.nvim",
            "neovim/nvim-lspconfig"
        },
        config = function()
            require("mason-lspconfig").setup({
                -- 自动安装的 LSP 服务器
                ensure_installed = {
{{- if .languages.python }}
                    "pyright",        -- Python
{{- end }}
{{- if or .languages.c .languages.cpp }}
                    "clangd",         -- C/C++
{{- end }}
{{- if .languages.lua }}
                    "lua_ls",         -- Lua
{{- end }}
{{- if .languages.go }}
                    "gopls",          -- Go
{{- end }}
{{- if .languages.rust }}
                    "rust_analyzer",  -- Rust
{{- end }}
                },
                -- 自动安装所有在 lspconfig 中配置的服务器
                automatic_installation = true,
            })
        end
    },
    -- Mason-Tool-Installer: 自动安装格式化工具和其他工具
    {
        "WhoIsSethDaniel/mason-tool-installer.nvim",
        dependencies = {
            "williamboman/mason.nvim"
        },
        config = function()
            require("mason-tool-installer").setup({
                -- 自动安装的工具列表
                ensure_installed = {
{{- if .languages.python }}
                    -- Formatters for Python
                    "black",
                    "isort",
{{- end }}
{{- if .languages.lua }}
                    -- Formatter for Lua
                    "stylua",
{{- end }}
{{- if or .languages.javascript .languages.typescript }}
                    -- Formatter for JSON/JSONC/JS/TS
                    "prettier",
{{- end }}
{{- if or .languages.c .languages.cpp }}
                    -- Formatter for C/C++
                    "clang-format",
{{- end }}
{{- if .languages.go }}
                    -- Formatters for Go
                    "goimports",
                    "gofumpt",
{{- end }}
{{- if .languages.rust }}
                    -- Formatter for Rust
                    "rustfmt",
{{- end }}
                },
                -- 自动更新工具
                auto_update = false,
                -- 启动时检查并安装缺失的工具
                run_on_start = true,
                -- 安装成功/失败时的提示
                start_delay = 3000, -- 3 秒延迟启动
            })
        end
    }
}
